{
  "name": "storehub",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:migrate": "pnpm --filter @storehub/db migrate",
    "db:seed": "pnpm --filter @storehub/db seed"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.38.3",
      "postgres": "3.4.5"
    }
  },
  "devDependencies": {
    "turbo": "2.3.3",
    "typescript": "5.7.3",
    "@types/node": "22.10.7",
    "esbuild": "0.24.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}